{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/refresh-stats",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/send-daily-report",
      "schedule": "45 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
