{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/sync-meta",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/sync-instagram",
      "schedule": "10 3 * * *"
    },
    {
      "path": "/api/sync-telegram",
      "schedule": "20 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
